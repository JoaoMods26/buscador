-- ============================================================
-- FETCH / RUN
-- ============================================================
local function fetchRawScript(url)
	local ok, r = pcall(function()
		return request({Url=url, Method="GET", Headers={["Content-Type"]="application/json"}})
	end)
	if ok and r and r.Body then
		local s, d = pcall(function() return HttpService:JSONDecode(r.Body) end)
		if s then return d else return r.Body end
	end
	return nil
end
local function getCode(raw)
	if type(raw)=="table" and type(raw.result)=="string" then return raw.result end
	if type(raw)=="string" then return raw end
	return nil
end
local function runCode(code)
	if not code then return end
	local fn, err = (loadstring or load)(code)
	if fn then local ok,e=pcall(fn); if not ok then warn("❌ exec:",e) end
	else warn("❌ compile:",err) end
end

