	JmodsMainFrame.BackgroundTransparency     = val
	JmodsResultsScroll.BackgroundTransparency = math.min(1, val + 0.1)
	JmodsCloseBtn.BackgroundTransparency      = val
	JmodsMinBtn.BackgroundTransparency        = val
	JmodsConfigBtn.BackgroundTransparency     = val
	JmodsTrendBtn.BackgroundTransparency      = val
	JmodsSearchBox.BackgroundTransparency     = math.min(1, val + 0.05)
	JmodsSearchBtn.BackgroundTransparency     = val
	for _, child in ipairs(JmodsResultsScroll:GetChildren()) do
		if child:IsA("Frame") then
			child.BackgroundTransparency = math.min(1, val + 0.1)
		end
	end
end

