local JmodsIntroLogo = Instance.new("ImageLabel", JmodsIntroFrame)
JmodsIntroLogo.Name                   = "JmodsIntroLogo"
JmodsIntroLogo.AnchorPoint            = Vector2.new(0.5, 0.5)
JmodsIntroLogo.Position               = UDim2.new(0.5,0,0.5,0)
JmodsIntroLogo.Size                   = UDim2.new(0,400,0,400)
JmodsIntroLogo.Image                  = "rbxassetid://128308831323216"
JmodsIntroLogo.BackgroundTransparency = 1
JmodsIntroLogo.ZIndex                 = 1000

local function runIntro()
	task.wait()  -- 1 frame para que GUI esté lista (fix intros invisibles)

	local ts   = TweenService
	local tipo = _rng:NextInteger(1, 10)

	JmodsIntroLogo.Visible           = true
	JmodsIntroLogo.ImageTransparency = 0
	JmodsIntroLogo.Rotation          = 0
	JmodsIntroLogo.Position          = UDim2.new(0.5,0,0.5,0)
	JmodsIntroLogo.Size              = UDim2.new(0,400,0,400)

	if tipo == 1 then
		JmodsIntroLogo.Size = UDim2.new(0,0,0,0)
		ts:Create(JmodsIntroLogo, TweenInfo.new(1, Enum.EasingStyle.Back),
			{Size=UDim2.new(0,400,0,400)}):Play()
		task.wait(2)
	elseif tipo == 2 then
		JmodsIntroLogo.Position = UDim2.new(0,-150,1,150)
		JmodsIntroLogo.Size     = UDim2.new(0,200,0,200)
		ts:Create(JmodsIntroLogo, TweenInfo.new(2, Enum.EasingStyle.Quint),
			{Position=UDim2.new(0.5,0,0.5,0), Size=UDim2.new(0,400,0,400)}):Play()
		task.wait(2.2)
	elseif tipo == 3 then
		JmodsIntroLogo.Size = UDim2.new(0,1000,0,1000)
		ts:Create(JmodsIntroLogo, TweenInfo.new(2), {Size=UDim2.new(0,400,0,400)}):Play()
		task.wait(2.2)
	elseif tipo == 4 then
		JmodsIntroLogo.Position = UDim2.new(0,-400,0.5,0)
		JmodsIntroLogo.Size     = UDim2.new(0,300,0,300)
		ts:Create(JmodsIntroLogo, TweenInfo.new(1.5),
			{Position=UDim2.new(1,400,0.5,0)}):Play()
		task.wait(1.6)
		ts:Create(JmodsIntroLogo, TweenInfo.new(0.6),
			{Position=UDim2.new(0.5,0,0.5,0), Size=UDim2.new(0,400,0,400)}):Play()
		task.wait(0.8)
	elseif tipo == 5 then
		JmodsIntroLogo.Rotation = -360
		JmodsIntroLogo.Size     = UDim2.new(0,0,0,0)
		ts:Create(JmodsIntroLogo, TweenInfo.new(2),
			{Size=UDim2.new(0,400,0,400), Rotation=0}):Play()
		task.wait(2.2)
	elseif tipo == 6 then
		JmodsIntroLogo.Position = UDim2.new(0.5,0,-0.5,0)
		JmodsIntroLogo.Size     = UDim2.new(0,250,0,250)
		ts:Create(JmodsIntroLogo, TweenInfo.new(1.5, Enum.EasingStyle.Bounce),
			{Position=UDim2.new(0.5,0,0.5,0), Size=UDim2.new(0,400,0,400)}):Play()
		task.wait(1.8)
	elseif tipo == 7 then
		local path = {
			UDim2.new(0.5,-300,0.1,0), UDim2.new(0.5,300,0.2,0),
			UDim2.new(0.5,-150,0.3,0), UDim2.new(0.5,75,0.4,0),
			UDim2.new(0.5,0,0.5,0)
		}
		JmodsIntroLogo.Position = UDim2.new(0.5,0,-0.2,0)
		JmodsIntroLogo.Size     = UDim2.new(0,300,0,300)
		for _, pos in ipairs(path) do
			ts:Create(JmodsIntroLogo, TweenInfo.new(0.25, Enum.EasingStyle.Bounce),
				{Position=pos}):Play()
			task.wait(0.27)
		end
	elseif tipo == 8 then
		JmodsIntroLogo.Rotation = -1440
		ts:Create(JmodsIntroLogo, TweenInfo.new(2, Enum.EasingStyle.Quad),
			{Rotation=0}):Play()
		task.wait(2.2)
	elseif tipo == 9 then
		for _ = 1, 6 do
			JmodsIntroLogo.Position          = UDim2.new(math.random(),0,math.random(),0)
			JmodsIntroLogo.ImageTransparency = 1
			task.wait(0.06)
			JmodsIntroLogo.ImageTransparency = 0
			task.wait(0.06)
		end
		JmodsIntroLogo.Position = UDim2.new(0.5,0,0.5,0)
		ts:Create(JmodsIntroLogo, TweenInfo.new(0.6),
			{Size=UDim2.new(0,400,0,400)}):Play()
		task.wait(1.2)
	elseif tipo == 10 then
		local clones = {}
		for _, dir in ipairs({
			Vector2.new(-1,-1), Vector2.new(1,-1),
			Vector2.new(-1,1),  Vector2.new(1,1)
		}) do
			local c = JmodsIntroLogo:Clone()
			c.Parent=JmodsIntroFrame; c.Position=UDim2.new(0.5,0,0.5,0)
			c.Size=UDim2.new(0,400,0,400); c.ImageTransparency=0
			table.insert(clones, c)
			ts:Create(c, TweenInfo.new(0.5),
				{Position=UDim2.new(0.5+dir.X,0,0.5+dir.Y,0), ImageTransparency=1}):Play()
		end
		task.wait(0.5)
		JmodsIntroLogo.Position=UDim2.new(0.5,0,0.5,0)
		JmodsIntroLogo.Size=UDim2.new(0,100,0,100)
		JmodsIntroLogo.ImageTransparency=1
		ts:Create(JmodsIntroLogo, TweenInfo.new(1),
			{Size=UDim2.new(0,400,0,400), ImageTransparency=0}):Play()
		task.wait(1.3)
		for _, c in ipairs(clones) do c:Destroy() end
	end

	ts:Create(JmodsIntroLogo, TweenInfo.new(0.8), {ImageTransparency=1}):Play()
	task.wait(0.9)
	pcall(function() JmodsIntroFrame:Destroy() end)
end

