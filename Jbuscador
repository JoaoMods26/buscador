-- FIREBASE
-- ============================================================
local FB = "https://scriptbloxxd-default-rtdb.firebaseio.com/scripts/"
local function saveToFirebase(q, s)
	pcall(function()
		request({ Url=FB..HttpService:UrlEncode(q)..".json", Method="PUT",
			Headers={["Content-Type"]="application/json"}, Body=HttpService:JSONEncode(s) })
	end)
end
local function loadFromFirebase(q)
	local ok, r = pcall(function()
		return request({ Url=FB..HttpService:UrlEncode(q)..".json", Method="GET" })
	end)
	if ok and r and r.Body then
		local s, d = pcall(function() return HttpService:JSONDecode(r.Body) end)
		if s and d then return d end
	end
	return nil
end

