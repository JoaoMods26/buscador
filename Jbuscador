-- ============================================================
-- SECUENCIA PRINCIPAL: INTRO → FADE-IN → CONFIG → HISTORIAL → NOTIF
-- Un único task.spawn = orden garantizado, sin race conditions.
-- ============================================================
task.spawn(function()

	-- PASO 1: Intro completa (bloqueante)
	runIntro()

	-- PASO 2: Mostrar MainFrame con fade-in
	JmodsMainFrame.Visible                = true
	JmodsMainFrame.BackgroundTransparency = 1
	for _, v in ipairs(JmodsMainFrame:GetDescendants()) do
		if v==JmodsConfigPanel or v:IsDescendantOf(JmodsConfigPanel) then continue end
		if v:IsA("Frame") or v:IsA("TextLabel") or v:IsA("TextButton")
		or v:IsA("ScrollingFrame") or v:IsA("ImageLabel") then
			v.Visible = false
		end
	end
	tw(JmodsMainFrame, {BackgroundTransparency=currentTransparency}, 1)
	task.wait(0.3)
	for _, v in ipairs(JmodsMainFrame:GetDescendants()) do
		if v==JmodsConfigPanel or v:IsDescendantOf(JmodsConfigPanel) then continue end
		if v:IsA("Frame") or v:IsA("TextLabel") or v:IsA("TextButton")
		or v:IsA("ScrollingFrame") or v:IsA("ImageLabel") then
			v.Visible = true
			if v:IsA("Frame") then
				v.BackgroundTransparency=1; tw(v,{BackgroundTransparency=currentTransparency},0.5)
			elseif v:IsA("TextLabel") or v:IsA("TextButton") then
				v.TextTransparency=1; tw(v,{TextTransparency=0},0.5)
			elseif v:IsA("ImageLabel") then
				v.ImageTransparency=1; tw(v,{ImageTransparency=0},0.5)
			end
		end
	end

	-- PASO 3: Restaurar config (imagen + transparencia + slider)
	if userConfig.backgroundId and userConfig.backgroundId~="" then
		JmodsBgImage.Image="rbxassetid://"..tostring(userConfig.backgroundId)
		JmodsBgImage.Visible=true
	end
	repositionTrending()  -- ahora MainFrame tiene AbsoluteSize real
	applyTransparency(currentTransparency)
	local sliderRel = math.clamp(currentTransparency/0.9, 0, 1)
	JmodsSliderFill.Size       = UDim2.new(sliderRel,0,1,0)
	JmodsSliderHandle.Position = UDim2.new(sliderRel,0,0.5,0)
	JmodsSliderLabel.Text      = "Transparencia: "..string.format("%.0f%%", currentTransparency*100)

	-- PASO 4: Historial y notificaciones
	showScripts(history, true)
	showNotification("Subscríbete: joao_mods","Apóyame y mira más scripts",
		"https://youtube.com/@joao_mods0?si=Pv8NCVM5sT4Vr4F0")
	task.spawn(function()
		while true do
			task.wait(600)
			showNotification("Recuerda","Para mejores resultados busca en inglés")
			task.wait(60)
			showNotification("Recuerda","No hagas tantas búsquedas tan rápido")
		end
	end)
end)

