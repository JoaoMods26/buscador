local function translateToEnglish(text)
	local ok, r = pcall(function()
		return request({
			Url="https://translate.googleapis.com/translate_a/single?client=gtx&sl=auto&tl=en&dt=t&q="
				..HttpService:UrlEncode(text), Method="GET"
		})
	end)
	if ok and r and r.Body then
		local s,d=pcall(function() return HttpService:JSONDecode(r.Body) end)
		if s and d and d[1] and d[1][1] and d[1][1][1] then return d[1][1][1] end
	end
	return text
end

