-- ============================================================
local _searchTs = {}
local function canSearch()
	local now=tick()
	for i=#_searchTs,1,-1 do if now-_searchTs[i]>5 then table.remove(_searchTs,i) end end
	if #_searchTs>=5 then return false end
	table.insert(_searchTs,now); return true
end

-- ============================================================
-- BUSCAR
-- ============================================================
local function searchScripts(query)
	query=(query or ""):match("^%s*(.-)%s*$")
	if query=="" then showScripts(history,true); return end
	if not canSearch() then return end
	for _,c in ipairs(JmodsResultsScroll:GetChildren()) do
		if c:IsA("Frame") or c:IsA("TextLabel") then c:Destroy() end
	end
	local JmodsSearchingLabel = Instance.new("TextLabel",JmodsResultsScroll)
	JmodsSearchingLabel.Name="JmodsSearchingLabel"; JmodsSearchingLabel.Size=UDim2.new(1,0,0,40)
	JmodsSearchingLabel.Text="🔄 buscando, por favor espera..."
	JmodsSearchingLabel.Font=Enum.Font.Gotham; JmodsSearchingLabel.TextSize=16
	JmodsSearchingLabel.TextColor3=Color3.fromRGB(255,255,255); JmodsSearchingLabel.BackgroundTransparency=1
	task.spawn(function()
		local tq=translateToEnglish(query)
		local all={}
		for page=1,4 do
			local url="https://scriptblox.com/api/script/search?q="..HttpService:UrlEncode(tq).."&page="..page
			local d=fetchRawScript(url)
			if d and d.result and d.result.scripts and #d.result.scripts>0 then
				for _,s in ipairs(d.result.scripts) do table.insert(all,s) end
			else break end
		end
		pcall(function() JmodsSearchingLabel:Destroy() end)
		if #all>0 then
			showScripts(all,false); task.spawn(saveToFirebase,query,all)
		else
			local fb=loadFromFirebase(query)
			if fb then showScripts(fb,false)
			else
				local JmodsNoResults = Instance.new("TextLabel",JmodsResultsScroll)
				JmodsNoResults.Name="JmodsNoResults"; JmodsNoResults.Size=UDim2.new(1,0,0,40)
				JmodsNoResults.Text="❌ Sin resultados."
				JmodsNoResults.TextColor3=Color3.new(1,1,1); JmodsNoResults.BackgroundTransparency=1
			end
		end
	end)
end

