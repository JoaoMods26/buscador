-- ============================================================
-- INTRO — 10 TIPOS ALEATORIOS
-- FIX CLAVE: task.wait() al inicio da 1 frame de gracia para que
-- la ScreenGui esté completamente renderizada. Sin este wait,
-- AbsoluteSize puede ser Vector2(0,0) y los tweens que dependen
-- de posición/tamaño no se ven, haciendo parecer que la intro
-- "no apareció". Se eliminó el guard animacionYaEjecutada porque
-- runIntro() solo se llama UNA vez desde el task.spawn principal.
-- ============================================================
math.randomseed(tick() + math.floor(os.clock() * 1000))
local _rng = Random.new()

local JmodsIntroFrame = Instance.new("Frame", JmodsGui)
JmodsIntroFrame.Name                   = "JmodsIntroFrame"
JmodsIntroFrame.Size                   = UDim2.new(1,0,1,0)
