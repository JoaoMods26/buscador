		while #_notifQ>0 do
			local data=table.remove(_notifQ,1)
			local nW=isMobile and 210 or 300
			local nH=data.link and (isMobile and 82 or 100) or (isMobile and 58 or 72)
			local JmodsNotifFrame=Instance.new("Frame",JmodsGui)
			JmodsNotifFrame.Name="JmodsNotifFrame"
			JmodsNotifFrame.Size=UDim2.new(0,nW,0,nH); JmodsNotifFrame.Position=UDim2.new(1,10,0,20)
			JmodsNotifFrame.BackgroundColor3=Color3.fromRGB(25,25,25)
			JmodsNotifFrame.BackgroundTransparency=0.2; JmodsNotifFrame.BorderSizePixel=0; JmodsNotifFrame.ZIndex=200
			Instance.new("UICorner",JmodsNotifFrame).CornerRadius=UDim.new(0,12)
			local _ng=Instance.new("UIGradient",JmodsNotifFrame)
			_ng.Color=ColorSequence.new{
				ColorSequenceKeypoint.new(0,Color3.fromRGB(60,120,255)),
				ColorSequenceKeypoint.new(1,Color3.fromRGB(255,60,90))
			}; _ng.Rotation=45
			local JmodsNotifTitle=Instance.new("TextLabel",JmodsNotifFrame)
			JmodsNotifTitle.Name="JmodsNotifTitle"
			JmodsNotifTitle.Size=UDim2.new(1,-20,0,30); JmodsNotifTitle.Position=UDim2.new(0,10,0,5)
			JmodsNotifTitle.Text=data.title; JmodsNotifTitle.Font=Enum.Font.FredokaOne
			JmodsNotifTitle.TextSize=isMobile and 16 or 20; JmodsNotifTitle.TextColor3=Color3.fromRGB(255,255,255)
			JmodsNotifTitle.BackgroundTransparency=1; JmodsNotifTitle.TextXAlignment=Enum.TextXAlignment.Left; JmodsNotifTitle.ZIndex=201
			local JmodsNotifMsg=Instance.new("TextLabel",JmodsNotifFrame)
			JmodsNotifMsg.Name="JmodsNotifMsg"
			JmodsNotifMsg.Size=UDim2.new(1,-20,0,26); JmodsNotifMsg.Position=UDim2.new(0,10,0,33)
			JmodsNotifMsg.Text=data.message; JmodsNotifMsg.Font=Enum.Font.Gotham
			JmodsNotifMsg.TextSize=isMobile and 12 or 15; JmodsNotifMsg.TextColor3=Color3.fromRGB(220,220,220)
			JmodsNotifMsg.BackgroundTransparency=1; JmodsNotifMsg.TextXAlignment=Enum.TextXAlignment.Left; JmodsNotifMsg.ZIndex=201
			if data.link then
				local JmodsNotifLink=Instance.new("TextButton",JmodsNotifFrame)
				JmodsNotifLink.Name="JmodsNotifLink"
				JmodsNotifLink.Size=UDim2.new(1,-20,0,24); JmodsNotifLink.Position=UDim2.new(0,10,0,nH-30)
				JmodsNotifLink.Text="▶ YouTube"; JmodsNotifLink.Font=Enum.Font.GothamBold
				JmodsNotifLink.TextSize=isMobile and 11 or 13
				JmodsNotifLink.BackgroundTransparency=1; JmodsNotifLink.TextColor3=Color3.fromRGB(0,200,255); JmodsNotifLink.ZIndex=201
				Instance.new("UICorner",JmodsNotifLink).CornerRadius=UDim.new(0,6)
				JmodsNotifLink.MouseButton1Click:Connect(function()
					if setclipboard then setclipboard(data.link) end
				end)
			end
			tw(JmodsNotifFrame,{Position=UDim2.new(1,-(nW+10),0,20)},0.4,Enum.EasingStyle.Back)
			task.wait(5)
			for _=1,10 do
				pcall(function()
					JmodsNotifFrame.BackgroundTransparency=math.min(1,JmodsNotifFrame.BackgroundTransparency+0.08)
				end)
				task.wait(0.05)
			end
			pcall(function() JmodsNotifFrame:Destroy() end)
			task.wait(0.3)
		end
		_notifActive=false
	end)
end

